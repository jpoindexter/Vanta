{
  "name": "vanta",
  "version": "0.9.4",
  "type": "module",
  "private": true,
  "description": "Vanta agent layer — goal-aware, scope-enforced operator runtime",
  "author": "Jason Poindexter <jason@theft.studio>",
  "main": "desktop-app/electron/main.mjs",
  "bin": {
    "vanta": "bin/vanta.mjs"
  },
  "scripts": {
    "vanta": "node --import tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "desktop:renderer:typecheck": "tsc --noEmit -p desktop-app/tsconfig.json",
    "desktop:dev": "vite --host 127.0.0.1 --config desktop-app/vite.config.ts",
    "desktop:build": "vite build --config desktop-app/vite.config.ts",
    "desktop:native": "npm run desktop:build && electron desktop-app/electron/main.mjs",
    "desktop:native:smoke": "npm run desktop:build && electron desktop-app/electron/main.mjs --smoke",
    "desktop:kernel-collision:smoke": "npm run desktop:pack && node scripts/desktop-kernel-collision-smoke.mjs",
    "desktop:devtools:smoke": "npm run desktop:build && node scripts/desktop-devtools-detached-smoke.mjs",
    "desktop:host:test": "node --test desktop-app/electron/project-root.node-test.mjs desktop-app/electron/runtime-paths.node-test.mjs && vitest run desktop-app/electron/tray.test.mjs",
    "desktop:kernel": "bash scripts/prepare-desktop-kernel.sh",
    "desktop:pack": "npm run desktop:build && npm run desktop:kernel && node scripts/package-desktop.mjs",
    "desktop:dist": "npm run desktop:build && npm run desktop:kernel && node scripts/package-desktop.mjs --dist",
    "desktop:release": "npm run desktop:build && npm run desktop:kernel && node scripts/package-desktop.mjs --dist --notarize",
    "desktop:sound:smoke": "npm run desktop:build && node scripts/desktop-completion-sound-smoke.mjs",
    "desktop:canvas:smoke": "npm run desktop:build && node --import tsx scripts/desktop-canvas-smoke.mjs",
    "desktop:companion:smoke": "npm run desktop:build && node --import tsx scripts/desktop-companion-smoke.mjs",
    "desktop:presence:smoke": "npm run desktop:build && node scripts/desktop-presence-smoke.mjs",
    "desktop:layout:smoke": "npm run desktop:build && node scripts/desktop-layout-smoke.mjs",
    "desktop:runtime-strip:smoke": "npm run desktop:build && node scripts/desktop-runtime-strip-smoke.mjs",
    "desktop:model-runtime-clarity:smoke": "npm run desktop:build && node scripts/desktop-model-runtime-clarity-smoke.mjs",
    "desktop:crypto-free:proof": "npm run desktop:pack && node scripts/desktop-crypto-free-proof.mjs && vitest run src/payments/service.test.ts src/payments/readiness.test.ts src/cli/payments-cmd.test.ts src/payments/contract.test.ts",
    "desktop:full-access:smoke": "npm run desktop:build && node scripts/desktop-full-access-warning-smoke.mjs",
    "desktop:sessions:smoke": "npm run desktop:build && node scripts/desktop-session-management-smoke.mjs",
    "desktop:context:smoke": "npm run desktop:build && node scripts/desktop-context-attachments-smoke.mjs",
    "desktop:recovery:smoke": "npm run desktop:build && node scripts/desktop-run-recovery-smoke.mjs",
    "desktop:provider-auth:smoke": "npm run desktop:build && node scripts/desktop-provider-auth-recovery-smoke.mjs",
    "desktop:local-origin:smoke": "npm run desktop:build && node scripts/desktop-local-origin-security-smoke.mjs",
    "desktop:schema-trace:smoke": "npm run desktop:build && node scripts/desktop-schema-trace-smoke.mjs",
    "schema:v1:proof": "node --import tsx scripts/schema-v1-release-proof.ts",
    "desktop:long-session:smoke": "npm run desktop:build && node scripts/desktop-long-session-navigation-smoke.mjs",
    "desktop:queue:smoke": "npm run desktop:build && node scripts/desktop-queued-turn-editor-smoke.mjs",
    "desktop:flow:proof:source": "npm run desktop:build && node scripts/desktop-flow-proof-suite.mjs --source-only",
    "desktop:flow:proof": "npm run desktop:pack && node scripts/desktop-flow-proof-suite.mjs",
    "desktop:operator-flows:smoke": "npm run desktop:build && node scripts/desktop-operator-flows-smoke.mjs",
    "desktop:google-connect:smoke": "npm run desktop:build && node scripts/desktop-google-connect-smoke.mjs",
    "desktop:shell-convergence:smoke": "npm run desktop:build && node scripts/desktop-shell-convergence-smoke.mjs",
    "desktop:visual:proof": "npm run desktop:build && node --test scripts/lib/desktop-visual-regression.node-test.mjs && VANTA_DESKTOP_VISUAL_PROOF=1 node scripts/desktop-shell-convergence-smoke.mjs",
    "desktop:accessibility:proof": "npm run desktop:pack && node scripts/desktop-accessibility-proof.mjs",
    "desktop:voiceover:proof": "node scripts/desktop-voiceover-proof.mjs",
    "desktop:visual:update": "npm run desktop:build && VANTA_DESKTOP_VISUAL_PROOF=1 VANTA_DESKTOP_VISUAL_UPDATE=1 node scripts/desktop-shell-convergence-smoke.mjs",
    "desktop:performance:proof": "npm run desktop:pack && node --test scripts/lib/desktop-performance-budget.node-test.mjs && node scripts/desktop-performance-budget.mjs",
    "desktop:performance:update": "npm run desktop:pack && node scripts/desktop-performance-budget.mjs --update",
    "desktop:live-turn:proof": "npm run desktop:build && node --test scripts/desktop-live-proof-diagnostics.node-test.mjs && node scripts/desktop-live-turn-proof.mjs",
    "local-runtime:v1:proof": "node --import tsx scripts/local-runtime-v1-release-proof.ts",
    "installer:managed:smoke": "bash ../scripts/managed-install-smoke.sh",
    "installer:managed:desktop:smoke": "bash ../scripts/managed-desktop-install-smoke.sh",
    "voice:wake:smoke": "node --import tsx scripts/voice-wake-smoke.ts",
    "payment:visa-tap:conformance": "vitest run src/payments/visa-tap.test.ts",
    "mobile:sync": "npm run desktop:build && cap sync ios",
    "mobile:open": "cap open ios",
    "sdk:build": "npm --prefix packages/sdk run build",
    "sdk:pack": "npm run sdk:build && mkdir -p .artifacts && npm pack ./packages/sdk --pack-destination .artifacts",
    "spreadsheet:sheets:smoke": "node scripts/google-sheets-sidecar-smoke.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@mozilla/readability": "^0.6.0",
    "@napi-rs/keyring": "^1.3.0",
    "@noble/curves": "2.2.0",
    "@tanstack/react-virtual": "^3.14.6",
    "exceljs": "^4.4.0",
    "google-auth-library": "^10.6.2",
    "imapflow": "1.4.2",
    "ink": "^7.0.6",
    "linkedom": "^0.18.12",
    "lucide-react": "^0.468.0",
    "nodemailer": "9.0.1",
    "openai": "^5.12.0",
    "pdfjs-dist": "6.0.227",
    "playwright-core": "^1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "web-tree-sitter": "^0.26.10",
    "winnow": "https://github.com/jpoindexter/winnow/archive/7d5756b72c32cb6bb46987ca9b85611a893d7cf1.tar.gz",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/node": "^22.15.0",
    "@types/nodemailer": "7.0.4",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "axe-core": "^4.12.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "build": {
    "appId": "studio.theft.vanta",
    "productName": "Vanta",
    "artifactName": "Vanta-${version}-${arch}.${ext}",
    "asar": true,
    "asarUnpack": [
      "node_modules/esbuild/**/*",
      "node_modules/@esbuild/**/*",
      "node_modules/tsx/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop-app/dist/**/*",
      "desktop-app/electron/**/*.mjs",
      "desktop-app/electron/**/*.cjs",
      "src/**/*",
      "package.json",
      "!node_modules/@huggingface/**/*",
      "!node_modules/onnxruntime-node/**/*",
      "!node_modules/onnxruntime-web/**/*",
      "!node_modules/lucide-react/**/*"
    ],
    "extraResources": [
      {
        "from": "../target/release/vanta-kernel",
        "to": "kernel/vanta-kernel"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "desktop-app/build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "Vanta ${version}",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 190,
          "type": "file"
        },
        {
          "x": 400,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "uuid": "^11.1.1"
  }
}
