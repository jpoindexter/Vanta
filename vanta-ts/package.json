{
  "name": "vanta",
  "version": "0.8.0",
  "type": "module",
  "private": true,
  "description": "Vanta agent layer — goal-aware, scope-enforced operator runtime",
  "bin": {
    "vanta": "bin/vanta.mjs"
  },
  "scripts": {
    "vanta": "node --import tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "desktop:dev": "vite --host 127.0.0.1 --config desktop-app/vite.config.ts",
    "desktop:build": "vite build --config desktop-app/vite.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@mozilla/readability": "^0.6.0",
    "@noble/curves": "2.2.0",
    "google-auth-library": "^10.6.2",
    "imapflow": "1.4.2",
    "ink": "^7.0.6",
    "linkedom": "^0.18.12",
    "nodemailer": "9.0.1",
    "openai": "^5.12.0",
    "pdfjs-dist": "6.0.227",
    "playwright-core": "^1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tree-sitter-bash": "^0.25.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "web-tree-sitter": "^0.26.10",
    "winnow": "github:jpoindexter/winnow#fae2c69de78f2534a30f8e0128ea5235a9a357d3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/nodemailer": "7.0.4",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
