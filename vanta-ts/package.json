{
  "name": "vanta",
  "version": "0.8.0",
  "type": "module",
  "private": true,
  "description": "Vanta agent layer — goal-aware, scope-enforced operator runtime",
  "author": "Jason Poindexter <jason@theft.studio>",
  "main": "desktop-app/electron/main.mjs",
  "bin": {
    "vanta": "bin/vanta.mjs"
  },
  "scripts": {
    "vanta": "node --import tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "desktop:renderer:typecheck": "tsc --noEmit -p desktop-app/tsconfig.json",
    "desktop:dev": "vite --host 127.0.0.1 --config desktop-app/vite.config.ts",
    "desktop:build": "vite build --config desktop-app/vite.config.ts",
    "desktop:native": "npm run desktop:build && electron desktop-app/electron/main.mjs",
    "desktop:native:smoke": "npm run desktop:build && electron desktop-app/electron/main.mjs --smoke",
    "desktop:host:test": "node --test desktop-app/electron/project-root.node-test.mjs && vitest run desktop-app/electron/tray.test.mjs",
    "desktop:kernel": "bash scripts/prepare-desktop-kernel.sh",
    "desktop:pack": "npm run desktop:build && npm run desktop:kernel && node scripts/package-desktop.mjs",
    "desktop:dist": "npm run desktop:build && npm run desktop:kernel && node scripts/package-desktop.mjs --dist",
    "desktop:release": "npm run desktop:build && npm run desktop:kernel && node scripts/package-desktop.mjs --dist --notarize",
    "desktop:sound:smoke": "npm run desktop:build && node scripts/desktop-completion-sound-smoke.mjs",
    "desktop:canvas:smoke": "npm run desktop:build && node --import tsx scripts/desktop-canvas-smoke.mjs",
    "desktop:companion:smoke": "npm run desktop:build && node --import tsx scripts/desktop-companion-smoke.mjs",
    "desktop:presence:smoke": "npm run desktop:build && node scripts/desktop-presence-smoke.mjs",
    "desktop:layout:smoke": "npm run desktop:build && node scripts/desktop-layout-smoke.mjs",
    "desktop:sessions:smoke": "npm run desktop:build && node scripts/desktop-session-management-smoke.mjs",
    "desktop:operator-flows:smoke": "npm run desktop:build && node scripts/desktop-operator-flows-smoke.mjs",
    "desktop:live-turn:proof": "npm run desktop:build && node scripts/desktop-live-turn-proof.mjs",
    "installer:managed:smoke": "bash ../scripts/managed-install-smoke.sh",
    "installer:managed:desktop:smoke": "bash ../scripts/managed-desktop-install-smoke.sh",
    "voice:wake:smoke": "node --import tsx scripts/voice-wake-smoke.ts",
    "mobile:sync": "npm run desktop:build && cap sync ios",
    "mobile:open": "cap open ios",
    "sdk:build": "npm --prefix packages/sdk run build",
    "sdk:pack": "npm run sdk:build && mkdir -p .artifacts && npm pack ./packages/sdk --pack-destination .artifacts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@mozilla/readability": "^0.6.0",
    "@noble/curves": "2.2.0",
    "exceljs": "^4.4.0",
    "google-auth-library": "^10.6.2",
    "imapflow": "1.4.2",
    "ink": "^7.0.6",
    "linkedom": "^0.18.12",
    "lucide-react": "^0.468.0",
    "nodemailer": "9.0.1",
    "openai": "^5.12.0",
    "pdfjs-dist": "6.0.227",
    "playwright-core": "^1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "web-tree-sitter": "^0.26.10",
    "winnow": "https://github.com/jpoindexter/winnow/archive/7d5756b72c32cb6bb46987ca9b85611a893d7cf1.tar.gz",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/node": "^22.15.0",
    "@types/nodemailer": "7.0.4",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "build": {
    "appId": "studio.theft.vanta",
    "productName": "Vanta",
    "artifactName": "Vanta-${version}-${arch}.${ext}",
    "asar": true,
    "asarUnpack": [
      "node_modules/esbuild/**/*",
      "node_modules/@esbuild/**/*",
      "node_modules/tsx/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop-app/dist/**/*",
      "desktop-app/electron/**/*.mjs",
      "src/**/*",
      "package.json",
      "!node_modules/@huggingface/**/*",
      "!node_modules/onnxruntime-node/**/*",
      "!node_modules/onnxruntime-web/**/*",
      "!node_modules/lucide-react/**/*"
    ],
    "extraResources": [
      {
        "from": "../target/release/vanta-kernel",
        "to": "kernel/vanta-kernel"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "desktop-app/build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "Vanta ${version}",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        { "x": 140, "y": 190, "type": "file" },
        { "x": 400, "y": 190, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "uuid": "^11.1.1"
  }
}
