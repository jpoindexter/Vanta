{
  "name": "vanta",
  "version": "0.8.0",
  "type": "module",
  "private": true,
  "description": "Vanta agent layer — goal-aware, scope-enforced operator runtime",
  "bin": {
    "vanta": "bin/vanta.mjs"
  },
  "scripts": {
    "vanta": "node --import tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "desktop:dev": "vite --host 127.0.0.1 --config desktop-app/vite.config.ts",
    "desktop:build": "vite build --config desktop-app/vite.config.ts",
    "desktop:native": "npm run desktop:build && electron desktop-app/electron/main.mjs",
    "desktop:native:smoke": "npm run desktop:build && electron desktop-app/electron/main.mjs --smoke",
    "desktop:sound:smoke": "npm run desktop:build && node scripts/desktop-completion-sound-smoke.mjs",
    "desktop:canvas:smoke": "npm run desktop:build && node --import tsx scripts/desktop-canvas-smoke.mjs",
    "desktop:companion:smoke": "npm run desktop:build && node --import tsx scripts/desktop-companion-smoke.mjs",
    "desktop:presence:smoke": "npm run desktop:build && node scripts/desktop-presence-smoke.mjs",
    "voice:wake:smoke": "node --import tsx scripts/voice-wake-smoke.ts",
    "mobile:sync": "npm run desktop:build && cap sync ios",
    "mobile:open": "cap open ios",
    "sdk:build": "npm --prefix packages/sdk run build",
    "sdk:pack": "npm run sdk:build && mkdir -p .artifacts && npm pack ./packages/sdk --pack-destination .artifacts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@mozilla/readability": "^0.6.0",
    "@noble/curves": "2.2.0",
    "google-auth-library": "^10.6.2",
    "imapflow": "1.4.2",
    "ink": "^7.0.6",
    "linkedom": "^0.18.12",
    "nodemailer": "9.0.1",
    "openai": "^5.12.0",
    "pdfjs-dist": "6.0.227",
    "playwright-core": "^1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tree-sitter-bash": "^0.25.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "web-tree-sitter": "^0.26.10",
    "winnow": "https://github.com/jpoindexter/winnow/archive/7d5756b72c32cb6bb46987ca9b85611a893d7cf1.tar.gz",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/node": "^22.15.0",
    "@types/nodemailer": "7.0.4",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "electron": "^43.1.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
