# Vanta agent configuration — copy to .env and adjust.

# Tip: `vanta setup` configures this interactively (merges into .env, preserves other keys).
#
# Provider: ollama (local, free) · openai · anthropic · gemini · openrouter
VANTA_PROVIDER=ollama
VANTA_MODEL=qwen2.5:14b

# OpenAI (when VANTA_PROVIDER=openai)
# VANTA_PROVIDER=openai
# VANTA_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# Google Gemini — OpenAI-compatible endpoint (when VANTA_PROVIDER=gemini)
# VANTA_PROVIDER=gemini
# VANTA_MODEL=gemini-2.5-flash
# GEMINI_API_KEY=...                   # https://aistudio.google.com/apikey

# OpenRouter — one key, 200+ models (when VANTA_PROVIDER=openrouter)
# VANTA_PROVIDER=openrouter
# VANTA_MODEL=anthropic/claude-sonnet-4.5
# OPENROUTER_API_KEY=...               # https://openrouter.ai/keys

# NVIDIA NIM (OpenAI-compatible; use as cheap worker route for summarize/classify)
# VANTA_PROVIDER=nvidia
# VANTA_MODEL=meta/llama-3.1-8b-instruct
# NVIDIA_API_KEY=...                   # https://build.nvidia.com/settings/api-keys

# Claude via your Pro/Max subscription (grey area — ToS; uses your `claude` login)
# VANTA_PROVIDER=claude-code            # reads ~/.claude/.credentials.json (sign in via `claude`)
# VANTA_MODEL=claude-sonnet-4-6
# CLAUDE_CODE_OAUTH_TOKEN=...          # optional: token instead of the creds file

# Ollama endpoint override (default http://localhost:11434/v1)
# VANTA_OLLAMA_URL=http://localhost:11434/v1

# Kernel sidecar URL (default http://127.0.0.1:7788)
# VANTA_KERNEL_URL=http://127.0.0.1:7788

# Max agent loop iterations (default 50)
# VANTA_MAX_ITER=50

# Auto-retry budget for idempotent reads that fail transiently (default 1, max 5;
# writes/shell/spawns are never retried). 0 disables.
# VANTA_TOOL_RETRIES=1

# CC-SANDBOX: opt-in OS-level isolation for shell_cmd + run_code (default OFF).
# When =1, commands run under macOS sandbox-exec (Seatbelt) / Linux bwrap: writes
# only under the project root + writable zones + temp; reads of ~/.ssh, ~/.aws,
# /etc, etc. are blocked; network is cut. It only ever TIGHTENS — never grants
# access. If =1 on a platform with no backend (e.g. Windows), Vanta REFUSES to run
# rather than run unsandboxed. Leave unset for byte-identical default behavior.
# VANTA_SANDBOX=1

# CC-SANDBOX network: allow the sandboxed command to reach the network (default
# OFF — the sandbox cuts the network). Only meaningful with VANTA_SANDBOX=1.
# VANTA_SANDBOX_NET=1

# CC-GOAL-CMD: max auto-continuation turns when a "/goal done when `cmd`" condition
# is not yet met (default 10). Each turn re-checks the condition automatically.
# VANTA_GOAL_LOOP_MAX=10

# CC-JSON-SCHEMA: force JSON output conforming to a schema. Pass a file path or
# inline JSON string. On validation failure the agent retries up to 3 times.
# --json-schema flag on `vanta run` takes precedence over this env var.
# VANTA_JSON_SCHEMA=/path/to/schema.json

# STALL-UNBLOCK: turns an active goal can go without a write/commit before Vanta
# suggests the smallest unblocker (default 4). 0 disables.
# VANTA_STALL_THRESHOLD=4

# MODE-DETECT: auto-infer the conversational stance (silent-executor/collaborator/
# critic/researcher/debugger) from each request. Set 0 to disable.
# VANTA_MODE_DETECT=1

# AUTO-HANDOFF: context fill fraction (0..1) that triggers an auto-saved resume
# block, reloaded on the next interactive launch (default 0.75). VANTA_AUTOHANDOFF=0 disables.
# VANTA_AUTOHANDOFF_THRESHOLD=0.75

# CODE-SIZE-GATE: make the pre-commit size check (vanta lint --staged) BLOCK the
# commit instead of warn-only (default warn so pre-existing debt never blocks).
# VANTA_LINT_BLOCK=1

# CC-AUTO-COMPACT: context fill fraction (0..1) that triggers automatic message
# compaction. Default 0.75 (75%). Lower = compact more aggressively.
# VANTA_AUTO_COMPACT_THRESHOLD=0.75

# CC-TOKEN-WARN-UI: status-bar context-limit warning. The % turns yellow with a
# /compact nudge at the warn fraction, red ("context full") at the urgent one.
# VANTA_TOKEN_WARN_FRAC=0.85
# VANTA_TOKEN_URGENT_FRAC=0.95

# CC-NO-FLICKER-ENV: launch the TUI in the alternate screen buffer so it never
# garbles or overwrites normal terminal history. Claude Code compat alias also
# accepted. Recommended for fullscreen or long sessions.
# VANTA_NO_FLICKER=1
# CLAUDE_CODE_NO_FLICKER=1

# TUI look + input
# VANTA_THEME=default                   # default | high-contrast | muted | dyslexia (/theme to switch live)
# VANTA_SPINNER=orbit                   # orbit | dots | pulse | snake | wave | asterisk
# VANTA_VIM=1                           # enable vim-mode composer editing
# VANTA_NO_MOUSE=1                      # disable mouse reporting → native click-drag text
#                                       # selection works again (loses wheel scroll; ⇧↑/↓ + pgup/pgdn still scroll)
# Keybindings: drop a ~/.vanta/keybindings.json to rebind any action, e.g.
#   { "transcript.toggleExpand": "ctrl+t", "palette.next": ["down", "ctrl+j"] }
# Action ids + defaults are listed in the in-TUI help overlay (type ? then ⏎).
# In the TUI, /cockpit opens mission-control (kernel verdict ladder · goals · loops).

# MessageDisplay: strip <thinking>…</thinking> blocks from the assistant text
# SHOWN on screen — the model and tools still receive the raw text. A built-in
# example of the message_display hook (transform/suppress before render). Off by default.
# VANTA_STRIP_THINKING=1

# Brain auto-learning: after a busy turn (>= MIN_TOOLS tool calls) or every Nth
# turn, a background pass distils 0-3 durable memories (user patterns -> user_model,
# facts -> semantic, Vanta's own forming personality -> identity/reflections) into
# the structured brain. On by default; VANTA_BRAIN_LEARN=0 disables.
# VANTA_BRAIN_LEARN=1
# VANTA_BRAIN_LEARN_EVERY=4
# VANTA_BRAIN_LEARN_MIN_TOOLS=5

# Brain entry budget: consolidation (gist-merge + decay sweep + weakest-dropped)
# keeps the structured memory store at or under this many entries (floor 50).
# VANTA_BRAIN_MAX_ENTRIES=400

# Session memory (the in-session scratchpad distiller; see memory/session-memory.ts).
# VANTA_SESSION_MEMORY=1
# VANTA_SESSION_MEMORY_EVERY=3
# VANTA_SESSION_MEMORY_MIN_TOOLS=5

# Auxiliary task — vision. Image tools (describe_image, look_at_screen) run on a
# DEDICATED vision model when set, so a text-only main model (DeepSeek, local
# Ollama) doesn't break sight. Unset = use the active provider (prior behavior).
# VANTA_VISION_MODEL=gpt-4o-mini        # the model that handles image work
# VANTA_VISION_PROVIDER=openai          # optional: its backend, if not VANTA_PROVIDER

# Authenticated browser (AUTH-BROWSER). `vanta browser auth <site>` opens a site
# in Vanta's OWN persistent profile (never the real browser's cookies) so you log
# in once; later headless browser tools reuse the session. Enabled automatically
# once the profile dir exists, or force it on with the flag below.
# VANTA_BROWSER_PROFILE_ENABLED=1       # force persistent profile for all browser tools
# VANTA_BROWSER_PROFILE=~/.vanta/browser-profile  # override the profile dir

# Self-improvement loop (default on). After a busy or periodic turn, a review
# agent captures a reusable skill; the curator archives stale learned skills.
# VANTA_SELF_IMPROVE=0                  # set 0/false to turn the loop off
# VANTA_REVIEW_MIN_TOOLS=6             # review fires when a turn uses >= N tools
# VANTA_REVIEW_EVERY=8                 # ...or every N turns in a session

# Gateway daemon (`vanta gateway` / `vanta service install`). Tick interval ms.
# VANTA_GATEWAY_TICK_MS=60000
# Telegram gateway: text Vanta from your phone. Token from @BotFather.
# VANTA_TELEGRAM_TOKEN=123456:ABC...    # set to enable the Telegram gateway
# VANTA_TELEGRAM_ALLOW=                 # optional comma-list of chat ids (empty = allow all)

# MCP servers to mount as tools (or use ~/.vanta/mcp.json). Inline JSON:
# VANTA_MCP_SERVERS={"servers":{"files":{"command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}}}

# Webhook triggers (inside `vanta gateway`). GitHub/etc. POST → agent turn → deliver.
# VANTA_WEBHOOK_PORT=8787
# VANTA_WEBHOOK_SECRET=...               # HMAC secret (x-hub-signature-256); UNSET = unauthenticated
# VANTA_WEBHOOK_PROMPT=Handle this webhook event:\n{body}   # {body} is the raw payload
# VANTA_WEBHOOK_DELIVER=local            # local | file:/path/out.log | telegram:<chatId>

# Web search (Phase 2B). Default: ddg (no key, no tracking).
# VANTA_SEARCH_PROVIDER=ddg            # ddg | searxng | serpapi | brave
# VANTA_SEARCH_URL=http://localhost:8080   # required for searxng (self-hosted, privacy-first)
# SERPAPI_KEY=...                      # required for serpapi
# BRAVE_KEY=...                        # required for brave

# Dark factory autonomy ladder (O10/O10b/O11). `vanta factory approve` reach:
# VANTA_AUTONOMY_LEVEL=4                # 1 suggest · 2 implement · 3 commit · 4 push · 5 merge (default 4)
# L5 auto-merge is OFF unless explicitly armed — the merge runs outside the kernel gate,
# so the low-risk classifier (limbs-only, no dep/env change, small diff) is the whole safety story.
# VANTA_AUTONOMY_ALLOW_MERGE=1         # arm L5 auto-merge (default UNSET = land at L4 push)
# VANTA_FACTORY_MERGE_TARGET=factory/integration   # where L5 lands; never main/master; must already exist

# CC-DIAGNOSTIC-BASELINE: after a .ts/.tsx write, surface only the diagnostics
# that edit INTRODUCED (filter pre-existing). Opt-in: runs two semantic TS
# builds per write, so it is off by default.
# VANTA_DIAGNOSTIC_DELTA=1

# CC-PROMPT-CACHE-1H: extend the Anthropic prompt-cache TTL on the stable system
# prefix from the default 5 minutes to 1 hour. Frugality win ONLY on long
# sessions — a 1h cache WRITE costs 2x base input tokens, so you need ~3+ cache
# reads within the hour to beat the 5-min TTL. Off by default; turn on for
# marathon/agentic runs. (Same env name Claude Code uses.)
# ENABLE_PROMPT_CACHING_1H=1
