# Vanta agent configuration — copy to .env and adjust.

# Tip: `vanta setup` configures this interactively (merges into .env, preserves other keys).
#
# Provider: ollama (local, free) · openai · anthropic · gemini · openrouter · nvidia
# · tokenrouter · deepseek · xai · groq · mistral · together · fireworks · cerebras
# · moonshot · minimax · codex · claude-code — OR any id you declare in
# ~/.vanta/providers.json (see providers.json.example: add ANY OpenAI-compatible
# backend with no code change; VANTA_MODEL accepts any model the endpoint serves).
VANTA_PROVIDER=ollama
VANTA_MODEL=qwen2.5:14b

# Model-call request timeout in seconds (PROVIDER-AWARE-WATCHDOG). Unset = a
# cold-start-aware per-provider default (ollama/lmstudio 1800, deepseek/nim/nvidia
# 900, custom 1200, everything else 600 = the SDK default). The liveness watchdog
# derives its stall window from this, so it never false-fires before a cold
# provider's own timeout could elapse. Raise it for a very slow local model.
# VANTA_PROVIDER_TIMEOUT_SEC=900

# PROVIDER-HARDENING: a long unattended run makes many model calls; a transient hiccup on one
# (idle/request timeout, 429, connection reset) is retried instead of crashing the run. Bounded
# retries (default 2) with a per-attempt backoff (default 500ms; ×(attempt+1)). Non-transient
# errors still fail fast; context-window errors still compact. Set retries 0 to disable.
# VANTA_PROVIDER_RETRIES=2
# VANTA_PROVIDER_RETRY_BACKOFF_MS=500

# Where /feedback files in-product GitHub issues (owner/name). Default: the Vanta repo.
# VANTA_FEEDBACK_REPO=jpoindexter/Vanta

# Force the full `vanta status` / `/status` dump (otherwise it auto-condenses on a
# non-default model or when output is piped). Same as `vanta status --verbose`.
# VANTA_STATUS_VERBOSE=1

# OpenAI (when VANTA_PROVIDER=openai)
# VANTA_PROVIDER=openai
# VANTA_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# Google Gemini — OpenAI-compatible endpoint (when VANTA_PROVIDER=gemini)
# VANTA_PROVIDER=gemini
# VANTA_MODEL=gemini-2.5-flash
# GEMINI_API_KEY=...                   # https://aistudio.google.com/apikey

# OpenRouter — one key, 200+ models (when VANTA_PROVIDER=openrouter)
# VANTA_PROVIDER=openrouter
# VANTA_MODEL=anthropic/claude-sonnet-4.5
# OPENROUTER_API_KEY=...               # https://openrouter.ai/keys

# NVIDIA NIM (OpenAI-compatible; use as cheap worker route for summarize/classify)
# VANTA_PROVIDER=nvidia
# VANTA_MODEL=meta/llama-3.1-8b-instruct
# NVIDIA_API_KEY=...                   # https://build.nvidia.com/settings/api-keys

# OpenAI Codex via your ChatGPT subscription (sign in via `codex login`; Responses API)
# VANTA_PROVIDER=codex
# VANTA_MODEL=gpt-5.5                    # default, most capable — start here
#   gpt-5.4            — fallback if 5.5 isn't in your account yet; native computer-use
#   gpt-5.4-mini       — subagents / lighter tasks: ~2x faster, ~30% of the quota
#   gpt-5.3-codex-spark — near-instant (1000+ tok/s), text-only, 128K ctx, ChatGPT Pro only
# (ChatGPT-auth tip: leaving VANTA_MODEL unset lets Codex track its current recommended default.)

# Claude via your Pro/Max subscription (grey area — ToS; uses your `claude` login)
# VANTA_PROVIDER=claude-code            # reads ~/.claude/.credentials.json (sign in via `claude`)
# VANTA_MODEL=claude-sonnet-4-6
# CLAUDE_CODE_OAUTH_TOKEN=...          # optional: token instead of the creds file

# Ollama endpoint override (default http://localhost:11434/v1)
# VANTA_OLLAMA_URL=http://localhost:11434/v1

# Local embeddings for life_search action:semantic (uses Ollama native /api/embeddings).
# Model must be pulled: `ollama pull nomic-embed-text`. Falls back to lexical ranking when
# Ollama is unreachable. VANTA_OLLAMA_URL is re-used for the base host (strip /v1 auto).
# VANTA_EMBED_MODEL=nomic-embed-text       # default; alternatives: mxbai-embed-large, all-minilm

# Kernel sidecar URL (default http://127.0.0.1:7788)
# VANTA_KERNEL_URL=http://127.0.0.1:7788

# Max agent loop iterations (default 50)
# VANTA_MAX_ITER=50

# Auto-retry budget for idempotent reads that fail transiently (default 1, max 5;
# writes/shell/spawns are never retried). 0 disables.
# VANTA_TOOL_RETRIES=1

# CC-SANDBOX: opt-in OS-level isolation for shell_cmd + run_code (default OFF).
# When =1, commands run under macOS sandbox-exec (Seatbelt) / Linux bwrap: writes
# only under the project root + writable zones + temp; reads of ~/.ssh, ~/.aws,
# /etc, etc. are blocked; network is cut. It only ever TIGHTENS — never grants
# access. If =1 on a platform with no backend (e.g. Windows), Vanta REFUSES to run
# rather than run unsandboxed. Leave unset for byte-identical default behavior.
# VANTA_SANDBOX=1

# Shell-only sandbox: same OS sandbox as VANTA_SANDBOX, but only for shell_cmd.
# run_code remains controlled by VANTA_SANDBOX. Background shell tasks are refused
# while shell sandboxing is enabled because they cannot safely clean up profiles.
# VANTA_SHELL_SANDBOX=1

# CC-SANDBOX network: allow the sandboxed command to reach the network (default
# OFF — the sandbox cuts the network). Meaningful with VANTA_SANDBOX=1 or
# VANTA_SHELL_SANDBOX=1.
# VANTA_SANDBOX_NET=1

# Execution backend: where shell_cmd / run_code run. "docker" runs each command in
# an ephemeral container (project root + writable zones + tmp mounted; network off
# unless VANTA_SANDBOX_NET=1; --rm so out-of-container writes don't persist). Falls
# back to local when the docker CLI is absent. Unset/"local" = this host (default).
# The kernel still gates every command regardless of backend.
# VANTA_EXEC_BACKEND=docker
# Image for the docker backend (needs whatever interpreters run_code will use).
# VANTA_DOCKER_IMAGE=alpine:latest

# SSH session backend (set by `vanta ssh user@host`, not normally by hand): every
# shell_cmd in the session runs on this host (a profile name or user@host). The
# kernel + permission prompts stay LOCAL; only command execution is remote.
# VANTA_SSH_SESSION=deploy@1.2.3.4

# Proactive heartbeat (KAIROS): when idle AND the user is away, `vanta proactive
# run` (cron-invoked) advances queued loop wakes on its own — throttled by idle
# time, cadence, a daily cap, and the budget hard-stop on budgetScope. Off by
# default. `vanta proactive status` shows whether it would tick now.
# VANTA_PROACTIVE=1
# VANTA_PROACTIVE_IDLE_MIN=15          # user must be away ≥ N minutes
# VANTA_PROACTIVE_INTERVAL_MIN=30      # ≥ N minutes between proactive ticks
# VANTA_PROACTIVE_MAX_PER_DAY=8        # daily tick cap
# VANTA_PROACTIVE_BUDGET_SCOPE=session # a tripped budget on this scope blocks ticks

# Proactive channel outreach: after a proactive tick advances queued work, Vanta
# messages you FIRST on a configured channel — strictly opt-in, throttled, and
# budget-bounded. Silence anytime: `vanta proactive silence <minutes|off>`.
# VANTA_OUTREACH=1
# VANTA_OUTREACH_TO=telegram:123456    # platform:chatId (any configured adapter)
# VANTA_OUTREACH_INTERVAL_MIN=30       # ≥ N minutes between unprompted messages
# VANTA_OUTREACH_MAX_PER_DAY=5         # daily cap on unprompted messages
# VANTA_OUTREACH_BUDGET_SCOPE=session  # a tripped budget on this scope blocks pings

# Channel approvals (CHANNEL-PERMISSIONS-WIRE): with a live messaging channel,
# ask-tier kernel approvals relay to the first approver chat as
# "yes/no <request-id>" prompts; an allowlisted reply resolves them, raced
# against a deny-at-timeout. Off unless approver chats are set.
# VANTA_APPROVER_CHATS=123456789               # comma list of chat ids allowed to approve
# VANTA_CHANNEL_APPROVAL_TIMEOUT_SEC=120       # deny at timeout when nobody replies

# CC-GOAL-CMD: max auto-continuation turns when a "/goal done when `cmd`" condition
# is not yet met (default 10). Each turn re-checks the condition automatically.
# VANTA_GOAL_LOOP_MAX=10

# CC-JSON-SCHEMA: force JSON output conforming to a schema. Pass a file path or
# inline JSON string. On validation failure the agent retries up to 3 times.
# --json-schema flag on `vanta run` takes precedence over this env var.
# VANTA_JSON_SCHEMA=/path/to/schema.json

# STALL-UNBLOCK: turns an active goal can go without a write/commit before Vanta
# suggests the smallest unblocker (default 4). 0 disables.
# VANTA_STALL_THRESHOLD=4

# MODE-DETECT: auto-infer the conversational stance (silent-executor/collaborator/
# critic/researcher/debugger) from each request. Set 0 to disable.
# VANTA_MODE_DETECT=1

# AUTO-HANDOFF: context fill fraction (0..1) that triggers an auto-saved resume
# block, reloaded on the next interactive launch (default 0.75). VANTA_AUTOHANDOFF=0 disables.
# VANTA_AUTOHANDOFF_THRESHOLD=0.75

# RESUME WINDOW: a restart carries the prior thread (auto-handoff + session-memory)
# ONLY if the last session was within this many minutes (default 120). A fresh start
# hours later is clean. 0 disables auto-resume entirely (every launch is a clean slate).
# Standing GOALS persist regardless — clear them with /goal clear or /goal done N.
# VANTA_RESUME_MAX_AGE_MIN=120

# CARRIED-GOAL MODE: a goal from a prior session starts PAUSED on launch — a fresh
# start does NOT silently re-run last session's task. Surfaced as a notice; pick it
# up with /goal resume or drop it with /goal clear. Set to "auto" to restore the old
# always-active behavior (the carried goal drives the agent immediately).
# VANTA_GOAL_RESUME=auto

# CODE-SIZE-GATE: make the pre-commit size check (vanta lint --staged) BLOCK the
# commit instead of warn-only (default warn so pre-existing debt never blocks).
# VANTA_LINT_BLOCK=1

# CC-AUTO-COMPACT: context fill fraction (0..1) that triggers automatic message
# compaction. Default 0.75 (75%). Lower = compact more aggressively.
# VANTA_AUTO_COMPACT_THRESHOLD=0.75

# Extended-thinking token budget for Anthropic/Claude models (0 = off). Surfaced
# in `vanta setup` as "Reasoning depth". Other providers ignore it.
# VANTA_THINKING_BUDGET=0

# Tool-progress verbosity for one-shot `vanta run` / REPL: full (calls + results,
# default) | compact (results only) | off (text only). The TUI always shows progress.
# VANTA_TOOL_PROGRESS=full

# CC-TOKEN-WARN-UI: status-bar context-limit warning. The % turns yellow with a
# /compact nudge at the warn fraction, red ("context full") at the urgent one.
# VANTA_TOKEN_WARN_FRAC=0.85
# VANTA_TOKEN_URGENT_FRAC=0.95

# CC-NO-FLICKER-ENV: launch the TUI in the alternate screen buffer so it never
# garbles or overwrites normal terminal history. another agent compat alias also
# accepted. Recommended for fullscreen or long sessions.
# VANTA_NO_FLICKER=1
# CLAUDE_CODE_NO_FLICKER=1

# TUI look + input
# VANTA_TUI=v2                         # opt into the mission-control v2 shell; unset/default keeps v1
#                                       # light = off-white terminal, near-black ink, muted teal accent (VNT-A palette)
# VANTA_SPINNER=orbit                   # orbit | dots | pulse | snake | wave | asterisk
# VANTA_VIM=1                           # enable vim-mode composer editing
# VANTA_MOUSE=1                         # enable mouse wheel scroll (default OFF — mouse tracking blocks
#                                       # native text selection; ⇧↑/↓ + pgup/pgdn scroll without it)
# Keybindings: drop a ~/.vanta/keybindings.json to rebind any action, e.g.
#   { "transcript.toggleExpand": "ctrl+t", "palette.next": ["down", "ctrl+j"] }
# Action ids + defaults are listed in the in-TUI help overlay (type ? then ⏎).
# In the TUI, /cockpit opens mission-control (kernel verdict ladder · goals · loops).

# MessageDisplay: strip <thinking>…</thinking> blocks from the assistant text
# SHOWN on screen — the model and tools still receive the raw text. A built-in
# example of the message_display hook (transform/suppress before render). Off by default.
# VANTA_STRIP_THINKING=1

# Brain auto-learning: after a busy turn (>= MIN_TOOLS tool calls) or every Nth
# turn, a background pass distils 0-3 durable memories (user patterns -> user_model,
# facts -> semantic, Vanta's own forming personality -> identity/reflections) into
# the structured brain. On by default; VANTA_BRAIN_LEARN=0 disables.
# VANTA_BRAIN_LEARN=1
# VANTA_BRAIN_LEARN_EVERY=4
# VANTA_BRAIN_LEARN_MIN_TOOLS=5

# Brain entry budget: consolidation (gist-merge + decay sweep + weakest-dropped)
# keeps the structured memory store at or under this many entries (floor 50).
# VANTA_BRAIN_MAX_ENTRIES=400

# Session memory (the in-session scratchpad distiller; see memory/session-memory.ts).
# VANTA_SESSION_MEMORY=1
# VANTA_SESSION_MEMORY_EVERY=3
# VANTA_SESSION_MEMORY_MIN_TOOLS=5

# Auxiliary task — vision. Image tools (describe_image, look_at_screen) run on a
# DEDICATED vision model when set, so a text-only main model (DeepSeek, local
# Ollama) doesn't break sight. Unset = use the active provider (prior behavior).
# VANTA_VISION_MODEL=gpt-4o-mini        # the model that handles image work
# VANTA_VISION_PROVIDER=openai          # optional: its backend, if not VANTA_PROVIDER

# WEB-EXTRACT-PIPELINE: web_fetch routes a page by extracted-text size instead of
# blindly truncating — as-is / single-pass summary / parallel-chunk+synthesize /
# refuse. Optional DEDICATED (often cheaper) model for the summarize/synthesis
# calls, same auxiliary-task pattern as vision. Unset = use the active provider.
# VANTA_EXTRACT_MODEL=gpt-4o-mini       # the model that handles big-page summarization
# VANTA_EXTRACT_PROVIDER=openai         # optional: its backend, if not VANTA_PROVIDER
# VANTA_EXTRACT_TIMEOUT_SEC=360         # its own request timeout, independent of VANTA_PROVIDER_TIMEOUT_SEC (default 360s)
# VANTA_EXTRACT_ASIS_MAX=5000           # chars: at/under this, returned as-is (default 5,000)
# VANTA_EXTRACT_SUMMARIZE_MAX=500000    # chars: at/under this, single-pass summary (default 500,000)
# VANTA_EXTRACT_CHUNK_MAX=2000000       # chars: at/under this, chunked+synthesized; above → refused (default 2,000,000)
# VANTA_EXTRACT_CHUNK_SIZE=100000       # chars per chunk in the chunk-synthesize tier (default 100,000)

# Voice / text-to-speech (the `speak` tool). Pick a backend with `vanta setup tts`.
# Unset = edge (keyless Microsoft neural voices; needs `pip install edge-tts`).
# VANTA_TTS_PROVIDER=edge                # edge | openai | elevenlabs | local (macOS say)
# VANTA_TTS_VOICE=en-US-AriaNeural       # voice id for the chosen backend
# OPENAI_API_KEY=...                     # required when VANTA_TTS_PROVIDER=openai
# ELEVENLABS_API_KEY=...                 # required when VANTA_TTS_PROVIDER=elevenlabs

# Authenticated browser (AUTH-BROWSER). `vanta browser auth <site>` opens a site
# in Vanta's OWN persistent profile (never the real browser's cookies) so you log
# in once; later headless browser tools reuse the session. Enabled automatically
# once the profile dir exists, or force it on with the flag below.
# VANTA_BROWSER_PROFILE_ENABLED=1       # force persistent profile for all browser tools
# VANTA_BROWSER_PROFILE=~/.vanta/browser-profile  # override the profile dir

# Self-improvement loop (default on). After a busy or periodic turn, a review
# agent captures a reusable skill; the curator archives stale learned skills.
# VANTA_SELF_IMPROVE=0                  # set 0/false to turn the loop off
# VANTA_REVIEW_MIN_TOOLS=6             # review fires when a turn uses >= N tools
# VANTA_REVIEW_EVERY=8                 # ...or every N turns in a session

# Gateway daemon (`vanta gateway` / `vanta service install`). Tick interval ms.
# VANTA_GATEWAY_TICK_MS=60000
# Telegram gateway: text Vanta from your phone. Token from @BotFather.
# VANTA_TELEGRAM_TOKEN=123456:ABC...    # set to enable the Telegram gateway
# VANTA_TELEGRAM_ALLOW=                 # optional comma-list of chat ids (empty = allow all)
# Mattermost gateway: a bot watches one channel via the REST API (polled).
# VANTA_MATTERMOST_URL=https://mm.example.com  # your Mattermost server URL
# VANTA_MATTERMOST_TOKEN=...                    # bot/personal access token
# VANTA_MATTERMOST_CHANNEL=...                  # the channel id to watch
# VANTA_MATTERMOST_ALLOW=                       # optional comma-list of channel ids (empty = allow all)
# ntfy gateway: pub/sub over ntfy.sh (used when no Telegram token is set).
# VANTA_NTFY_TOPIC=my-vanta-topic       # set to enable the ntfy gateway (topic name, not URL)
# VANTA_NTFY_SERVER=https://ntfy.sh     # optional self-hosted ntfy server
# VANTA_NTFY_ALLOW=                     # optional comma-list of topics (empty = allow all)

# MCP servers to mount as tools (or use ~/.vanta/mcp.json). Inline JSON:
# VANTA_MCP_SERVERS={"servers":{"files":{"command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}}}
# Surface MCP servers' declared prompts as Vanta skills/slash commands (/mcp-<server>-<prompt>,
# also listed by /skills). Each invocation is kernel-gated. Default off.
# VANTA_MCP_SKILLS=1

# Webhook triggers (inside `vanta gateway`). GitHub/etc. POST → agent turn → deliver.
# VANTA_WEBHOOK_PORT=8787
# VANTA_WEBHOOK_SECRET=...               # HMAC secret (x-hub-signature-256); UNSET = unauthenticated
# VANTA_WEBHOOK_PROMPT=Handle this webhook event:\n{body}   # {body} is the raw payload
# VANTA_WEBHOOK_DELIVER=local            # local | file:/path/out.log | telegram:<chatId>

# Web search. Default 'auto' chains: keyed providers (if their keys are set) →
# keyless fallbacks — so search works out of the box with NO key. `auto` now LEADS
# with brave_browser: a real chromium page reads Brave Search where the raw-HTTP
# scrapers (DDG) get IP-403'd. Needs the playwright chromium binary; no API key.
# VANTA_SEARCH_PROVIDER=auto           # auto | firecrawl | tavily | parallel | exa | xai | brave_browser | bing | jina_ddg | ddg | searxng | serpapi | brave
# VANTA_SEARCH_URL=http://localhost:8080   # required for searxng (self-hosted, privacy-first)
# SERPAPI_KEY=...                      # required for serpapi
# BRAVE_KEY=...                        # required for brave
# EXA_API_KEY=...                      # required for exa (neural/semantic search; native domain filtering; ~1k searches/mo free)
# Managed search+extract backends (auto-detected in priority order: firecrawl > parallel > tavily > exa):
# FIRECRAWL_API_KEY=...                # required for firecrawl (500 credits/mo; native domain filtering)
# TAVILY_API_KEY=...                   # required for tavily (1k searches/mo; native domain filtering)
# PARALLEL_API_KEY=...                 # required for parallel (objective + excerpts; site: rewrite for domains)
# xAI/Grok native live search — a reasoning model performs the search itself and
# returns ONE grounded answer with inline citations (not a REST result index).
# Citations map to SearchResults; native domain filtering, capped at 5 each.
# XAI_API_KEY=...                       # required for xai
# VANTA_XAI_SEARCH_MODEL=grok-4.3       # optional model override (default grok-4.3)

# Reach — X/Twitter (native GraphQL, no Python). Cookie via cookie_import "twitter";
# query ids via `reach heal twitter`. These are escape hatches when X rotates internals:
# VANTA_TWITTER_QID_BOOKMARKS=...      # set the Bookmarks GraphQL query id (lazy chunk; grab from devtools)
# VANTA_TWITTER_QID_SEARCHTIMELINE=... # override the SearchTimeline query id
# VANTA_TWITTER_BEARER=...             # override the web bearer token
# VANTA_TWITTER_FEATURES={...}         # override the GraphQL features blob (JSON) if X adds a required flag

# Dark factory autonomy ladder (O10/O10b/O11). `vanta factory approve` reach:
# VANTA_AUTONOMY_LEVEL=4                # 1 suggest · 2 implement · 3 commit · 4 push · 5 merge (default 4)
# L5 auto-merge is OFF unless explicitly armed — the merge runs outside the kernel gate,
# so the low-risk classifier (limbs-only, no dep/env change, small diff) is the whole safety story.
# VANTA_AUTONOMY_ALLOW_MERGE=1         # arm L5 auto-merge (default UNSET = land at L4 push)
# VANTA_FACTORY_MERGE_TARGET=factory/integration   # where L5 lands; never main/master; must already exist

# CC-DIAGNOSTIC-BASELINE: after a .ts/.tsx write, surface only the diagnostics
# that edit INTRODUCED (filter pre-existing). Opt-in: runs two semantic TS
# builds per write, so it is off by default.
# VANTA_DIAGNOSTIC_DELTA=1

# CC-PROMPT-CACHE-1H: extend the Anthropic prompt-cache TTL on the stable system
# prefix from the default 5 minutes to 1 hour. Frugality win ONLY on long
# sessions — a 1h cache WRITE costs 2x base input tokens, so you need ~3+ cache
# reads within the hour to beat the 5-min TTL. Off by default; turn on for
# marathon/agentic runs. (Same env name another agent uses.)
# ENABLE_PROMPT_CACHING_1H=1

# --- 2026-06-20 rock-grind knobs (all OFF/safe by default) ---
# VANTA_MAX_SPAWN_DEPTH=6          # kernel halts a spawn chain deeper than this (runaway backstop)
# VANTA_CAPABILITY_PRESERVE=1      # /explain: plain-English what+why + comprehension probe on risky/large changes
# VANTA_TEMPLATES=1                # classify common task patterns + augment the sent message with a terse approach block
# VANTA_SESSION_MEMORY_COMPACT=1   # on compaction, distil the dropped window's facts + tools-seen into .vanta/session-memory.md
# VANTA_FACTORY_HOLDOUT=1          # factory verify: a SEPARATE provider authors + checks acceptance criteria
# VANTA_AUTO_CLASSIFIER=1          # advisory tighten-only permission classifier (allow→ask/block, never loosen)

# --- 2026-06-21 operator rocks (all opt-in; live use needs the noted CLI/permission) ---
# VANTA_VOICE_PTT=1                 # enable composer push-to-talk voice input (needs `whisper` + `ffmpeg` CLIs + Mic permission)
# VANTA_STT_MODEL=tiny             # whisper model for voice STT (default tiny — fast + local)
# VANTA_TERMINAL_CAPTURE=1         # enable the terminal_capture tool (tmux-backed live capture)
# VANTA_SLACK_TOKEN=xoxb-...       # Slack token for #channel autocomplete (or VANTA_SLACK_BOT_TOKEN)
# VANTA_CHICAGO_MCP=chicago        # name of the mounted CHICAGO computer-use MCP server for native desktop control
# VANTA_LORA_AUTO=1                # auto-train a personal LoRA each gateway tick once enough preference pairs accrue
# VANTA_LORA_BASE_MODEL=...        # base model for `vanta tune lora` (heavy first run downloads it)

# --- network egress policy (NET-EGRESS-POLICY; on top of the private-IP/SSRF guard) ---
# VANTA_EGRESS_DENY=evil.com,*.tracker.net   # block outbound to these domains (deny wins; subdomains included)
# VANTA_EGRESS_ALLOW=github.com,*.anthropic.com  # if set, ONLY these domains are allowed (default-deny everything else)
# VANTA_ALLOW_PRIVATE_FETCH=1       # opt OUT of the private-IP/loopback/metadata guard (deliberate LAN access)
