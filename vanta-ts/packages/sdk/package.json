{
  "name": "@jpoindexter/vanta-operator-sdk",
  "version": "1.0.0",
  "description": "Typed client for the Vanta public API",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jpoindexter/Vanta.git",
    "directory": "vanta-ts/packages/sdk"
  },
  "homepage": "https://github.com/jpoindexter/Vanta/tree/main/vanta-ts/packages/sdk",
  "sideEffects": false,
  "files": ["dist", "README.md"],
  "main": "./dist/index.js",
