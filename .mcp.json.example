{
  "mcpServers": {
    "terminal-love": {
      "command": "node",
      "args": ["/absolute/path/to/terminal love mcp/dist/index.js"]
    },
    "example-server": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-example"],
      "env": {
        "API_KEY": "your-api-key-here"
      }
    }
  }
}
