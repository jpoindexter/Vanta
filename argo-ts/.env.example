# Argo agent configuration — copy to .env and adjust.

# Tip: `argo setup` configures this interactively (merges into .env, preserves other keys).
#
# Provider: ollama (local, free) · openai · anthropic · gemini · openrouter
ARGO_PROVIDER=ollama
ARGO_MODEL=qwen2.5:14b

# OpenAI (when ARGO_PROVIDER=openai)
# ARGO_PROVIDER=openai
# ARGO_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# Google Gemini — OpenAI-compatible endpoint (when ARGO_PROVIDER=gemini)
# ARGO_PROVIDER=gemini
# ARGO_MODEL=gemini-2.5-flash
# GEMINI_API_KEY=...                   # https://aistudio.google.com/apikey

# OpenRouter — one key, 200+ models (when ARGO_PROVIDER=openrouter)
# ARGO_PROVIDER=openrouter
# ARGO_MODEL=anthropic/claude-sonnet-4.5
# OPENROUTER_API_KEY=...               # https://openrouter.ai/keys

# Ollama endpoint override (default http://localhost:11434/v1)
# ARGO_OLLAMA_URL=http://localhost:11434/v1

# Kernel sidecar URL (default http://127.0.0.1:7788)
# ARGO_KERNEL_URL=http://127.0.0.1:7788

# Max agent loop iterations (default 50)
# ARGO_MAX_ITER=50

# Self-improvement loop (default on). After a busy or periodic turn, a review
# agent captures a reusable skill; the curator archives stale learned skills.
# ARGO_SELF_IMPROVE=0                  # set 0/false to turn the loop off
# ARGO_REVIEW_MIN_TOOLS=6             # review fires when a turn uses >= N tools
# ARGO_REVIEW_EVERY=8                 # ...or every N turns in a session

# Gateway daemon (`argo gateway` / `argo service install`). Tick interval ms.
# ARGO_GATEWAY_TICK_MS=60000
# Telegram gateway: text Argo from your phone. Token from @BotFather.
# ARGO_TELEGRAM_TOKEN=123456:ABC...    # set to enable the Telegram gateway
# ARGO_TELEGRAM_ALLOW=                 # optional comma-list of chat ids (empty = allow all)

# MCP servers to mount as tools (or use ~/.argo/mcp.json). Inline JSON:
# ARGO_MCP_SERVERS={"servers":{"files":{"command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}}}

# Web search (Phase 2B). Default: ddg (no key, no tracking).
# ARGO_SEARCH_PROVIDER=ddg            # ddg | searxng | serpapi | brave
# ARGO_SEARCH_URL=http://localhost:8080   # required for searxng (self-hosted, privacy-first)
# SERPAPI_KEY=...                      # required for serpapi
# BRAVE_KEY=...                        # required for brave
